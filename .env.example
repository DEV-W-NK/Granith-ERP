# Copie este arquivo para .env.local e preencha somente no ambiente local.
# Nunca versionar .env.local, chaves reais, service_role ou client secret OAuth.

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=SUA_CHAVE_PUBLICA_SUPABASE

GEMINI_API_KEY=SUA_CHAVE_GEMINI_SOMENTE_DEV
GEMINI_MODEL=gemini-2.5-flash

GOOGLE_MAPS_API_KEY=SUA_CHAVE_GOOGLE_MAPS_SOMENTE_DEV

# OAuth Google fica configurado no Google Cloud e no Supabase Auth.
# Estes campos sao apenas checklist local; o client secret NUNCA vai para o Flutter.
GOOGLE_OAUTH_WEB_CLIENT_ID=SEU_CLIENT_ID_WEB
GOOGLE_OAUTH_ANDROID_CLIENT_ID=SEU_CLIENT_ID_ANDROID
GOOGLE_OAUTH_IOS_CLIENT_ID=SEU_CLIENT_ID_IOS
GOOGLE_OAUTH_CLIENT_SECRET=SEU_CLIENT_SECRET_SOMENTE_LOCAL
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:61886
