# Copie para supabase/.env.local quando for servir/deployar Edge Functions.
# Nunca versionar service_role, tokens de gestao ou chave privada Firebase.

# O Supabase injeta SUPABASE_URL, SUPABASE_ANON_KEY e SUPABASE_SERVICE_ROLE_KEY
# no ambiente hospedado. Para desenvolvimento local, preencha se necessario.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=SUA_CHAVE_ANON_OU_PUBLISHABLE
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_SOMENTE_BACKEND

GRANITH_MANAGEMENT_API_TOKEN=coloque_o_token_como_secret_no_supabase_nao_no_repo
GRANITH_PROJECT_REF=opcional_se_quiser_fixar_o_project_ref
GRANITH_PUSH_DISPATCH_TOKEN=token_opcional_para_chamar_o_dispatch_sem_sessao_web
GRANITH_DEBUG_ERRORS=false

FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# Alternativa ao JSON completo:
FIREBASE_PROJECT_ID=granith-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@granith-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
